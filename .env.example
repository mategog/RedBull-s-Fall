# Copy to .env and fill in. .env is gitignored.
# Used to switch the Spark session factory between local and Databricks.

# "local"  -> local PySpark (offline dev + tests)
# "databricks" -> Databricks Connect against Free Edition serverless
SPARK_TARGET=local

# Databricks Free Edition (only needed when SPARK_TARGET=databricks)
# Host looks like: https://dbc-xxxxxxxx-xxxx.cloud.databricks.com
DATABRICKS_HOST=
DATABRICKS_TOKEN=

# Where the medallion layers are written.
# Local: a path on disk. Databricks: a Unity Catalog volume or DBFS path.
DATA_ROOT=./data
